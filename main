# =============================================================================
# Basic Simulator
# =============================================================================

from qiskit.providers.basic_provider import BasicSimulator

sim_basic = BasicSimulator()   #creating simulator object

qc = QuantumCircuit(2,2)
qc.reset(0)
qc.reset(1)
qc.h(1)
qc.measure(1,1)
qc.x(0)
qc.measure(0,0) 
display(qc.draw('mpl'))

job = sim_basic.run(qc,shots=100)
result = job.result()
counts = result.get_counts()
print(counts)

#from qiskit.visualization import plot_distribution
#display(plot_distribution(counts))

# as we do sampling in quantum info
job = sim_basic.run(qc,shots=100,memory= True)
result = job.result()
samples =result.get_memory()
print(samples)


from qiskit.providers.basic_provider import BasicSimulator

sim_basic = BasicSimulator()

# from qiskit.circuit.library import QFT

# qc = QuantumCircuit(3,3)
# qc.append(QFT(3),range(3))
# qc.measure(range(3),range(3))
# display(qc.draw("mpl"))

# QFT is not part of basis gates, that basic simulator runs
# So, we transpile our circuits

from qiskit import transpile

qc_t = transpile(qc, backend=sim_basic)

job = sim_basic.run(qc_t,shots=100)
result = job.result()
counts = result.get_counts()
print(counts)


# Aer Simulator

from qiskit_aer import AerSimulator

sim_aer = AerSimulator()
 
qc = QuantumCircuit(2,2)
qc.h(1)
qc.measure(1,0)
qc.h(0) 
qc.measure(0,0) 
display(qc.draw('mpl'))

from qiskit import transpile

qc_t = transpile(qc, backend=sim_aer)
job = sim_aer.run(qc_t,shots=10)
result = job.result()

counts = result.get_counts()
print(counts)


qc = QuantumCircuit(4)
qc.h(3)
qc.cx(3,2)
qc.save_statevector()  #we can save statevector anywhere between circuit
qc.cx(3,1)
qc.cx(3,0)
qc.measure_all()
display(qc.draw('mpl'))

qc_aer = transpile(qc, backend=sim_aer)
job = sim_aer.run(qc_aer,shots=1024)
result= job.result()

counts = result.get_counts()
print(counts)

phi = result.get_statevector()
print(phi)



